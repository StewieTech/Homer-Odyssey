{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/StewieTech/Homer-Odyssey/schemas/odyssey-target-registry.schema.json",
  "title": "Homer Odyssey Target Registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "limits", "targets"],
  "properties": {
    "apiVersion": { "const": "homer.odyssey/v1" },
    "kind": { "const": "OdysseyTargetRegistry" },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxTargetsPerRun", "concurrency", "maxRetries", "maxRateLimitWaitMs"],
      "properties": {
        "maxTargetsPerRun": { "type": "integer", "minimum": 1, "maximum": 32 },
        "concurrency": { "type": "integer", "minimum": 1, "maximum": 8 },
        "maxRetries": { "type": "integer", "minimum": 0, "maximum": 4 },
        "maxRateLimitWaitMs": { "type": "integer", "minimum": 0, "maximum": 60000 }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "repository", "targetRef", "profile", "channel", "packageFilters", "compatiblePackages", "policyHash"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
          "targetRef": { "type": "string", "minLength": 1 },
          "profile": { "type": "string", "pattern": "^[A-Za-z0-9._/-]+$" },
          "channel": { "enum": ["stable"] },
          "packageFilters": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[A-Za-z0-9*._/-]+$" },
            "uniqueItems": true
          },
          "compatiblePackages": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^(character|skill):[A-Za-z0-9*._/-]+$" },
            "uniqueItems": true
          },
          "policyHash": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" }
        }
      }
    }
  }
}
