{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/StewieTech/Homer-Odyssey/schemas/target-profile.schema.json",
  "title": "Homer Odyssey Target Profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "id", "version", "displayName", "lockfile", "capabilities", "paths", "sources", "vocabulary", "validationCommands", "overlays", "packageAllowlist", "projection"],
  "properties": {
    "apiVersion": { "const": "homer.odyssey/v1" },
    "kind": { "const": "TargetProfile" },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$" },
    "displayName": { "type": "string", "minLength": 1 },
    "lockfile": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "denied", "humanGated"],
      "properties": {
        "allowed": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "denied": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "humanGated": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protected", "managed"],
      "properties": {
        "protected": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
        "managed": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "url", "role"],
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string" },
          "role": { "enum": ["incubator", "canonical", "target"] }
        }
      }
    },
    "vocabulary": { "type": "object", "additionalProperties": { "type": "string" } },
    "validationCommands": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "overlays": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "packageAllowlist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["characters", "skills"],
      "properties": {
        "characters": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "skills": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generatedMarker", "mappings"],
      "properties": {
        "generatedMarker": { "type": "string", "minLength": 1 },
        "mappings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "target"],
            "properties": {
              "source": { "type": "string", "minLength": 1 },
              "target": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
