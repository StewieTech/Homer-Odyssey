{
  "character-passport": {
    "apiVersion": "homer.odyssey/v1",
    "kind": "CharacterPassport",
    "id": "marge",
    "version": "1.0.0",
    "name": "Marge",
    "role": "Product architect",
    "purpose": "Route product architecture work",
    "traits": ["evidence-first"],
    "capabilities": ["filesystem.read"],
    "dependencies": { "characters": [], "skills": ["ralph-prime"], "helpers": ["./prompt.md"] },
    "permissions": { "requested": ["filesystem.read"], "prohibited": ["production.mutate"] },
    "context": { "required": ["CONTEXT.md"], "optional": ["docs/adr"] },
    "adapters": ["codex"],
    "evals": ["routing"],
    "compatibility": { "homer": ">=0.1.0", "targets": ["studio"] }
  },
  "skill-manifest": {
    "apiVersion": "homer.odyssey/v1",
    "kind": "SkillManifest",
    "id": "ralph-prime",
    "version": "1.0.0",
    "title": "Ralph Prime",
    "corePaths": ["SKILL.md"],
    "dependencies": { "packages": [], "helpers": ["RUBRIC.md"] },
    "capabilities": ["filesystem.read"],
    "variables": [{ "name": "ISSUE_TRACKER", "required": true, "description": "Tracker kind" }],
    "outputs": ["implementation-plan"],
    "validation": ["node --test"],
    "upgrades": { "from": ["0.9.0"], "instructions": "Review profile vocabulary." }
  },
  "target-profile": {
    "apiVersion": "homer.odyssey/v1",
    "kind": "TargetProfile",
    "id": "test",
    "version": "1.0.0",
    "displayName": "Test Studio",
    "capabilities": { "allowed": ["filesystem.read"], "denied": ["production.mutate"], "humanGated": ["filesystem.write"] },
    "paths": { "protected": ["AGENTS.md"], "managed": [".homer/generated/**"] },
    "sources": [{ "id": "source", "url": "https://example.test/source", "role": "incubator" }],
    "vocabulary": { "agent": "character" },
    "validationCommands": ["node --test"],
    "overlays": ["overlays/test/**"],
    "packageAllowlist": { "characters": ["marge"], "skills": ["ralph"] },
    "projection": { "generatedMarker": "Generated by Homer", "mappings": [{ "source": ".agents/skills/**", "target": ".homer/generated/skills/**" }] }
  },
  "homer": {
    "apiVersion": "homer.odyssey/v1",
    "kind": "OdysseyTarget",
    "sourceRoot": "./source",
    "targetRoot": "./target",
    "profile": "./profile.json"
  },
  "homer-lock": {
    "apiVersion": "homer.odyssey/v1",
    "kind": "OdysseyLock",
    "source": { "commit": "abc", "hash": "source-hash" },
    "target": { "inputCommit": "def", "inputHash": "target-hash" },
    "profile": { "id": "studio", "version": "1.0.0", "hash": "profile-hash" },
    "transformerVersion": "0.1.0",
    "overlayHash": "overlay-hash",
    "packages": [{ "id": "ralph", "version": "1.0.0", "hash": "package-hash" }],
    "removedCapabilities": [],
    "deniedDependencies": [],
    "generatedFiles": [{ "path": ".homer/generated/ralph.md", "hash": "file-hash" }],
    "validation": [{ "name": "schema", "passed": true }],
    "rollback": { "previousLockHash": "previous", "instructions": "Restore the prior pinned projection." }
  },
  "dependency-graph": {
    "apiVersion": "homer.odyssey/v1",
    "kind": "DependencyGraph",
    "nodes": [{ "id": "source:SKILL.md", "type": "file" }],
    "edges": [],
    "missing": [],
    "cycles": [],
    "conflicts": []
