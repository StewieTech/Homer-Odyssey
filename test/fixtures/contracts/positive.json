  "inventory": {
    "apiVersion": "homer.odyssey/v1",
    "kind": "OdysseyInventory",
    "inputs": {
      "source": { "root": "/source", "commit": "abc", "hash": "source-hash" },
      "target": { "root": "/target", "commit": "def", "hash": "target-hash" },
      "profile": { "id": "studio", "version": "1.0.0", "hash": "profile-hash" }
    },
    "entries": [{ "repository": "source", "path": "SKILL.md", "hash": "hash", "size": 1, "references": [], "dependencies": [], "capabilities": [], "statuses": ["source-only"] }],
