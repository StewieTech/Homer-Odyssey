{
  "apiVersion": "homer.odyssey/v1",
  "kind": "TargetProfile",
  "id": "fixture-studio",
  "version": "1.0.0",
  "displayName": "Fixture Studio",
  "lockfile": "homer.lock",
  "capabilities": { "allowed": ["filesystem.read"], "denied": ["production.mutate"], "humanGated": ["filesystem.write"] },
  "paths": { "protected": ["AGENTS.md"], "managed": [".homer/generated/**"] },
  "sources": [{ "id": "fixture", "url": "https://example.test/fixture", "role": "incubator" }],
  "vocabulary": { "agent": "character" },
  "validationCommands": ["node --test"],
  "overlays": ["overlays/fixture/**"],
  "packageAllowlist": { "characters": [], "skills": ["ralph"] },
  "projection": { "generatedMarker": "<!-- Generated by Homer Odyssey; do not edit directly. -->", "mappings": [{ "source": ".agents/skills/**", "target": ".homer/generated/skills/**" }] },
  "sanitization": {
    "version": "1.0.0",
    "targetRepository": "fixture/target",
    "targetBaseBranch": "main",
    "allowedCharacterPackages": [],
    "allowedSkillPackages": ["ralph"],
    "nativeSkillNames": { "ralph": "ralph" },
    "targetVocabulary": { "agent": "character" },
    "requiredSourceDocs": ["AGENTS.md"],
    "validationCommands": ["node --test"],
    "substitutions": { "paths": {}, "repositories": {}, "branches": {} },
    "capabilities": { "allowed": ["filesystem.read"], "humanGated": ["filesystem.write"], "denied": ["production.mutate"] },
    "deniedPatterns": ["StewieTech/Pariss", "developSIT"],
    "protectedPaths": [".agents/**", "AGENTS.md"],
    "managedNativeSkillPaths": [".agents/skills/ralph"],
    "localPrecedence": ["AGENTS.md"],
    "requiredOverlays": [],
    "minimumPackageVersions": {},
    "failOnUnresolvedPlaceholder": true,
    "failOnSourceSpecificLeakage": true,
    "failOnUnmanagedConflict": true,
    "evidenceOutputPath": ".homer/generated/install/sanitization-report.json"
  }
}
