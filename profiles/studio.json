{
  "apiVersion": "homer.odyssey/v1",
  "kind": "TargetProfile",
  "id": "studio",
  "version": "1.0.0",
  "displayName": "MaxCharacterWork Studio",
  "capabilities": {
    "allowed": [
      "filesystem.read",
      "repository.diff",
      "repository.inspect",
      "repository.plan",
      "tests.run"
    ],
    "denied": [
      "auth.policy.mutate",
      "billing.mutate",
      "cors.policy.mutate",
      "entitlement.policy.mutate",
      "exploit.write",
      "operational-abuse.perform",
      "production.mutate",
      "secret.export",
      "session.policy.mutate",
      "social.stealth-automate"
    ],
    "humanGated": [
      "external.publish",
      "filesystem.write",
      "github.write",
      "production.deploy",
      "pull-request.merge"
    ]
  },
  "paths": {
    "protected": [
      "AGENTS.md",
      "agent.md",
      "CONTEXT.md",
      "LANGUAGE.md",
      "launch-gates.md",
      "package.json",
      "docs/adr/**",
      "docs/ai-influencer-os/**",
      "docs/platform-risk/**",
      "src/**"
    ],
    "managed": [
      ".homer/generated/**"
    ]
  },
  "sources": [
    {
      "id": "pariss",
      "url": "https://github.com/StewieTech/Pariss",
      "role": "incubator"
    },
    {
      "id": "homer-odyssey",
      "url": "https://github.com/StewieTech/Homer-Odyssey",
      "role": "canonical"
    },
    {
      "id": "max-character-work",
      "url": "https://github.com/StewieTech/MaxCharacterWork",
      "role": "target"
    }
  ],
  "vocabulary": {
    "agent": "character",
    "operation": "Odyssey Run",
    "plan": "Odyssey Plan",
    "product": "Studio"
  },
  "validationCommands": [
    "npm run typecheck",
    "npm test",
    "npm run lint"
  ],
  "overlays": [
    "profiles/overlays/studio/**"
  ],
  "packageAllowlist": {
    "characters": [
      "lisa",
      "marge-product-architect",
      "ralph-prime"
    ],
    "skills": [
      "lisa-prime",
      "ralph",
      "ralph-fixer",
      "ralph-prime"
    ]
  },
  "projection": {
    "generatedMarker": "<!-- Generated by Homer Odyssey; do not edit directly. -->",
    "mappings": [
      {
        "source": ".agents/characters/**",
        "target": ".homer/generated/characters/**"
      },
      {
        "source": ".agents/skills/**",
        "target": ".homer/generated/skills/**"
      }
    ]
  }
}
