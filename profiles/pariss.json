{
  "apiVersion": "homer.odyssey/v1",
  "kind": "TargetProfile",
  "id": "pariss",
  "version": "1.0.0",
  "displayName": "Pariss incubator projection",
  "lockfile": "homer.lock",
  "capabilities": {
    "allowed": ["filesystem.read", "repository.diff", "repository.inspect", "repository.plan", "tests.run"],
    "denied": ["auth.policy.mutate", "billing.mutate", "cors.policy.mutate", "entitlement.policy.mutate", "exploit.write", "operational-abuse.perform", "production.mutate", "secret.export", "session.policy.mutate", "social.stealth-automate"],
    "humanGated": ["external.publish", "filesystem.write", "github.write", "production.deploy", "pull-request.merge"]
  },
  "paths": { "protected": ["AGENTS.md", "CONTEXT.md", "docs/adr/**", "src/**"], "managed": [".homer/generated/**"] },
  "sources": [{ "id": "pariss", "url": "https://github.com/StewieTech/Pariss", "role": "incubator" }, { "id": "homer-odyssey", "url": "https://github.com/StewieTech/Homer-Odyssey", "role": "canonical" }],
  "vocabulary": { "agent": "character", "operation": "Ralph run", "plan": "execution packet", "product": "Pariss" },
  "validationCommands": ["npm test"],
  "overlays": ["profiles/overlays/pariss/**"],
  "packageAllowlist": { "characters": ["lisa", "lorie", "marge", "ralph", "ralph-prime"], "skills": ["lisa", "lisa-prime", "lorie", "marge-product-architect", "ralph", "ralph-prime"] },
  "projection": {
    "generatedMarker": "<!-- Generated by Homer Odyssey; do not edit directly. -->",
    "mappings": [
      { "source": "packages/characters/**", "target": ".homer/generated/characters/**" },
      { "source": "packages/skills/**", "target": ".homer/generated/skills/**" }
    ]
  }
}
