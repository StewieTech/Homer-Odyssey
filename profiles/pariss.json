{
  "apiVersion": "homer.odyssey/v1",
  "kind": "TargetProfile",
  "id": "pariss",
  "version": "1.0.0",
  "displayName": "Pariss incubator projection",
  "lockfile": "homer.lock",
  "capabilities": {
    "allowed": ["filesystem.read", "repository.diff", "repository.inspect", "repository.plan", "tests.run"],
    "denied": ["auth.policy.mutate", "billing.mutate", "cors.policy.mutate", "entitlement.policy.mutate", "exploit.write", "operational-abuse.perform", "production.mutate", "secret.export", "session.policy.mutate", "social.stealth-automate"],
    "humanGated": ["external.publish", "filesystem.write", "github.write", "production.deploy", "pull-request.merge"]
  },
  "paths": { "protected": ["AGENTS.md", "CONTEXT.md", "docs/adr/**", "src/**"], "managed": [".homer/generated/**"] },
  "sources": [{ "id": "pariss", "url": "https://github.com/StewieTech/Pariss", "role": "incubator" }, { "id": "homer-odyssey", "url": "https://github.com/StewieTech/Homer-Odyssey", "role": "canonical" }],
  "vocabulary": { "agent": "character", "operation": "Ralph run", "plan": "execution packet", "product": "Pariss" },
  "validationCommands": ["npm test"],
  "overlays": ["profiles/overlays/pariss/**"],
  "packageAllowlist": { "characters": ["lisa", "lisa-prime", "lorie", "marge", "ralph", "ralph-prime"], "skills": ["lisa", "lisa-prime", "lorie", "marge-product-architect", "ralph", "ralph-prime"] },
  "projection": {
    "generatedMarker": "<!-- Generated by Homer Odyssey; do not edit directly. -->",
    "mappings": [
      { "source": "packages/characters/**", "target": ".homer/generated/characters/**" },
      { "source": "packages/skills/**", "target": ".homer/generated/skills/**" }
    ]
  },
  "sanitization": {
    "version": "1.0.0",
    "targetRepository": "StewieTech/Pariss",
    "targetBaseBranch": "developSIT",
    "allowedCharacterPackages": ["lisa", "lisa-prime", "lorie", "marge", "ralph", "ralph-prime"],
    "allowedSkillPackages": ["lisa", "lisa-prime", "lorie", "marge-product-architect", "ralph", "ralph-prime"],
    "nativeSkillNames": { "lisa": "lisa", "lisa-prime": "lisa-prime", "lorie": "lorie", "marge-product-architect": "marge-product-architect", "ralph": "ralph", "ralph-prime": "ralph-prime" },
    "targetVocabulary": { "agent": "character", "operation": "Ralph run", "plan": "execution packet", "product": "Pariss" },
    "requiredSourceDocs": ["AGENTS.md"],
    "validationCommands": ["npm test"],
    "substitutions": { "paths": {}, "repositories": {}, "branches": {} },
    "capabilities": {
      "allowed": ["filesystem.read", "repository.diff", "repository.inspect", "repository.plan", "tests.run"],
      "humanGated": ["external.publish", "filesystem.write", "github.write", "production.deploy", "pull-request.merge"],
      "denied": ["auth.policy.mutate", "billing.mutate", "cors.policy.mutate", "entitlement.policy.mutate", "exploit.write", "operational-abuse.perform", "production.mutate", "secret.export", "session.policy.mutate", "social.stealth-automate"]
    },
    "deniedPatterns": ["\\bsk-[A-Za-z0-9_-]{12,}\\b", "\\bghp_[A-Za-z0-9]{20,}\\b", "\\bAKIA[A-Z0-9]{16}\\b"],
    "protectedPaths": [".agents/**", "AGENTS.md", "CONTEXT.md", "docs/adr/**", "src/**"],
    "managedNativeSkillPaths": [".agents/skills/lisa", ".agents/skills/lisa-prime", ".agents/skills/lorie", ".agents/skills/marge-product-architect", ".agents/skills/ralph", ".agents/skills/ralph-prime"],
    "localPrecedence": ["AGENTS.md", "CONTEXT.md", "docs/adr/**"],
    "requiredOverlays": [],
    "minimumPackageVersions": {},
    "failOnUnresolvedPlaceholder": true,
    "failOnSourceSpecificLeakage": false,
    "failOnUnmanagedConflict": true,
    "evidenceOutputPath": ".homer/generated/install/sanitization-report.json"
  }
}
